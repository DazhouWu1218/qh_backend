<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN" "http://mybatis.org/dtd/mybatis-3-mapper.dtd">

<mapper namespace="com.njht.webyun.publish.region.dao.RegionInfoDao">

	<!-- 可根据自己的需求，是否要使用 -->
    <resultMap type="com.njht.webyun.publish.region.entity.RegionInfoEntity" id="regionInfoMap">
        <result property="regionid" column="regionid"/>
        <result property="tMRegionid" column="t_m_regionid"/>
        <result property="regionlevel" column="regionlevel"/>
        <result property="fullname" column="fullname"/>
        <result property="districtname" column="districtname"/>
        <result property="enable" column="enable"/>
        <result property="bottom" column="bottom"/>
        <result property="lat" column="lat"/>
        <result property="left" column="left"/>
        <result property="lon" column="lon"/>
        <result property="right" column="right"/>
        <result property="top" column="top"/>
        <result property="theGemo" column="the_gemo"/>
    </resultMap>
    <select id="selectGeoByRegionId" resultType="java.lang.String">
        SELECT the_gemo FROM htht_region_geo_info WHERE regionid= #{regionId}
    </select>

    <select id="selectSimpleGeoByRegionId" resultType="java.lang.String">
        SELECT the_gemo FROM htht_region_geo_info WHERE regionid= #{regionId}
    </select>

    <select id="selectRegionList" resultType="com.njht.webyun.publish.region.entity.RegionInfoEntity">
        SELECT
			regionid,t_m_regionid,regionlevel,fullname,if(sort_key is NULL,0,sort_key) as sort_key
		FROM
			`htht_region_info`
		order by
		   regionid asc
    </select>
    <select id="selectRegionListByParentId" resultType="com.njht.webyun.publish.region.entity.RegionInfoEntity">
        SELECT
			regionid,t_m_regionid,regionlevel,fullname
		FROM
			`htht_region_info`
		WHERE
		     t_m_regionid = #{regionId}
	    ORDER BY
	        regionid asc
    </select>
    <select id="getGeoInfo" resultType="com.njht.webyun.publish.region.entity.RegionGeoInfoEntity">
        SELECT a.regionid,b.the_gemo FROM `htht_region_info` a
        LEFT JOIN htht_region_geo_info b
        on a.regionid = b.regionid
        WHERE a.t_m_regionid = #{regionId}
    </select>


</mapper>