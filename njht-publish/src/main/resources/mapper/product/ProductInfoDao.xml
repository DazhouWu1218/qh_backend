<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN" "http://mybatis.org/dtd/mybatis-3-mapper.dtd">

<mapper namespace="com.njht.webyun.publish.product.dao.ProductInfoDao">

	<!-- 可根据自己的需求，是否要使用 -->
    <resultMap type="com.njht.webyun.publish.product.entity.ProductInfoEntity" id="productInfoMap">
        <id property="id" column="id"/>
        <result property="createTime" column="create_time"/>
        <result property="updateTime" column="update_time"/>
        <result property="version" column="version"/>
        <result property="cycle" column="cycle"/>
        <result property="name" column="name"/>
        <result property="issue" column="issue"/>
        <result property="mark" column="mark"/>
        <result property="mapUrl" column="map_url"/>
        <result property="productPath" column="product_path"/>
        <result property="gdbPath" column="gdb_path"/>
        <result property="productId" column="product_id"/>
        <result property="regionId" column="region_id"/>
        <result property="isRelease" column="is_release"/>
        <result property="bz" column="bz"/>
        <result property="mosaicFile" column="mosaic_file"/>
        <result property="inputFileName" column="input_file_name"/>
        <result property="modelIdentify" column="model_identify"/>
        <result property="satellite" column="satellite"/>
        <result property="sensor" column="sensor"/>
        <result property="resolution" column="resolution"/>
    </resultMap>

    <resultMap id="productInfoDtoMap"  extends="productInfoMap" type="com.njht.webyun.publish.product.dto.ProductInfoDto">
        <collection property="fileInfoEntityList" ofType="TreeJson" select="selectProductFileInfos" column="id"></collection>
    </resultMap>

    <select id="selectProductFileInfos" resultType="com.njht.webyun.publish.product.entity.ProductFileInfoEntity">
		select
			id,file_type,file_path,file_name,is_del,relative_path
		from
			htht_cluster_schedule_product_file_info
		where
			product_info_id = #{id}
		order by
		 	file_name
		desc
	</select>

    <select id="selectCycleAndNameInfo" resultType="com.njht.webyun.publish.product.entity.ProductInfoEntity">
        SELECT
            DISTINCT product_id,name,satellite,cycle
        FROM
            `htht_cluster_schedule_product_info`
        WHERE
        product_id in
        <foreach collection="productIds" index="index" item="productId" open="(" separator="," close=")" >
            #{productId}
        </foreach>

    </select>
    <select id="selectProductDistinctList" resultType="com.njht.webyun.publish.product.entity.ProductInfoEntity">
        SELECT DISTINCT f.cycle,f.product_id,f.satellite,f.name,h.tree_id
        FROM `htht_cluster_schedule_product_info` f
        LEFT JOIN htht_cluster_schedule_product h
        ON f.product_id = h.id
        WHERE h.tree_id in
        <foreach collection="treeIdList" index="index" item="id" open="(" separator="," close=")" >
            #{id}
        </foreach>
        ORDER BY product_id desc
    </select>
    <select id="selectProductInfoList" resultMap="productInfoDtoMap">
        SELECT
        id,create_time,cycle,name,map_url,product_path,region_id,satellite,issue,mosaic_file,model_identify as mark,sensor,resolution,product_id
        FROM
        htht_cluster_schedule_product_info
        WHERE
            product_id = #{productId}
        <if test="cycleList!=null and cycleList.size()!=0  ">
            AND cycle in
            <foreach collection="cycleList" index="index" item="cycle" open="(" separator="," close=")" >
                #{cycle}
            </foreach>
        </if>
        <if test="dataSourceList!=null and dataSourceList.size()!=0 ">
            AND satellite in
            <foreach collection="dataSourceList" index="index" item="dataSource" open="(" separator="," close=")" >
                #{dataSource}
            </foreach>
        </if>
        <if test="regionList!=null and regionList.size()!=0">
            AND region_id in
            <foreach collection="regionList" index="index" item="region" open="(" separator="," close=")" >
                #{region}
            </foreach>
        </if>
        <if test="startTime!=null and startTime!='' ">
            AND issue &gt; #{begin}
        </if>
        <if test="endTime!=null and endTime!='' ">
            AND issue &lt;= #{end}
        </if>
        ORDER BY issue desc
    </select>
    <select id="selectEntityList" resultType="com.njht.webyun.publish.product.entity.ProductInfoEntity">
        SELECT
          a.*,b.tree_Id
        FROM
        htht_cluster_schedule_product_info a
        LEFT JOIN htht_cluster_schedule_product b
        ON a.product_id = b.id
        WHERE
        a.id in
        <foreach collection="idList" index="index" item="id" open="(" separator="," close=")" >
            #{id}
        </foreach>
    </select>


</mapper>