<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN" "http://mybatis.org/dtd/mybatis-3-mapper.dtd">

<mapper namespace="com.njht.webyun.publish.product.dao.ProductFileInfoDao">

	<!-- 可根据自己的需求，是否要使用 -->
    <resultMap type="com.njht.webyun.publish.product.entity.ProductFileInfoEntity" id="productFileInfoMap">
        <result property="id" column="id"/>
        <result property="createTime" column="create_time"/>
        <result property="updateTime" column="update_time"/>
        <result property="version" column="version"/>
        <result property="filePath" column="file_path"/>
        <result property="fileType" column="file_type"/>
        <result property="productId" column="product_id"/>
        <result property="productType" column="product_type"/>
        <result property="isDel" column="is_del"/>
        <result property="relativePath" column="relative_path"/>
        <result property="cycle" column="cycle"/>
        <result property="issue" column="issue"/>
        <result property="menuId" column="menu_id"/>
        <result property="region" column="region"/>
        <result property="zt" column="zt"/>
        <result property="fileName" column="file_name"/>
        <result property="fileSize" column="file_size"/>
        <result property="productInfoId" column="product_info_id"/>
    </resultMap>
    <select id="selectFileTypeList" resultType="com.njht.webyun.publish.product.entity.ProductFileInfoEntity">
        SELECT
            id,file_type,product_info_id,file_path,relative_path,file_name
        FROM
          htht_cluster_schedule_product_file_info
        WHERE product_info_id IN
        <foreach collection="idList" index="index" item="id" open="(" separator="," close=")" >
            #{id}
        </foreach>

    </select>

    <select id="selectProductFileInfoByTreeId" resultType="com.njht.webyun.publish.product.entity.ProductFileInfoEntity">
        SELECT file_path,relative_path
        FROM `htht_cluster_schedule_product_file_info`
        WHERE product_info_id in (
            SELECT a.id
            FROM `htht_cluster_schedule_product_info` a
            LEFT JOIN htht_cluster_schedule_product b
            ON a.product_id = b.id
            LEFT JOIN htht_cluster_schedule_data_category c
            ON b.tree_id = c.id
            where b.tree_id = #{id}  and a.region_id = #{regionId} and a.is_release = 1  ORDER BY a.issue  desc
        ) and file_type = "JPG" ORDER BY issue desc LIMIT 4
    </select>


</mapper>