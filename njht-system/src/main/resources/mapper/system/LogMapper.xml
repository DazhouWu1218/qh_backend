    <select id="getLoginBehaviorCountToday" parameterType="java.lang.Integer" resultType="java.lang.Integer">
        select count(*) from publish_behavior_log where action = 0 and TO_DAYS(created_date) = TO_DAYS(NOW()) and created_by = #{userId,jdbcType=INTEGER}
    </select>

    <insert id="addLoginBehavior" parameterType="map">
