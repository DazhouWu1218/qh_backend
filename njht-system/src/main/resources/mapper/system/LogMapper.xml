    <update id="updateLoginBehavior" parameterType="map">
        update publish_behavior_log set
        last_updated_by = #{lastUpdatedBy,jdbcType=INTEGER},
        last_updated_date = #{lastUpdatedDate,jdbcType=TIMESTAMP},
        num = num + 1
        where action = 0 and TO_DAYS(created_date) = TO_DAYS(now()) and created_by = #{lastUpdatedBy,jdbcType=INTEGER}
