<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN" "http://mybatis.org/dtd/mybatis-3-mapper.dtd">

<mapper namespace="com.njht.webyun.product.dao.RoleCategoryDao">

    <insert id="insertCategoryRoleList">
        INSERT INTO
            `htht_role_category`
        (`role_id`, `category_id`)
        VALUES
        <foreach collection="roleCategoryEntityList" index="index" item="item" open="" close="" separator=",">
            (#{item.roleId}, #{item.categoryId})
        </foreach>
    </insert>
    <delete id="deleteCategoryRoleList">
        DELETE FROM `htht_role_category`
        where ROLE_ID = #{roleId}
        AND
        category_id in
        <foreach collection="delCategoryIdList" index="index" item="item" open="(" close=")" separator=",">
             #{item}
        </foreach>
    </delete>
    <select id="selectCategoryIdList" resultType="java.lang.String">
        SELECT category_id
        FROM htht_role_category
        WHERE 1=1
        <if test="idList != null and idList.size > 0">
            AND role_id  in
            <foreach collection="idList" index="index" item="id" open="(" separator="," close=")" >
                #{id}
            </foreach>
        </if>

    </select>

</mapper>