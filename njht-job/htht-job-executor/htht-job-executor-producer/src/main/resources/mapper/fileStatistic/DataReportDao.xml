<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN" "http://mybatis.org/dtd/mybatis-3-mapper.dtd">

<mapper namespace="com.htht.executor.fileStatistic.dao.DataReportDao">

    <insert id="insertList">
        INSERT INTO `htht_cluster_schedule_data_report`
        (`id`, `create_time`, `update_time`, `version`, `bz`, `issue`, `cycle`, `file_num`, `sum_num`, `file_size`,
        `identify`, `status`, `data_id`, `data_name`)
        VALUES
        <foreach collection="dataList" item="item" separator=",">
            (#{item.id}, now(), now(), #{item.version}, #{item.bz}, #{item.issue}, #{item.cycle}, #{item.fileNum},
            #{item.sumNum}, #{item.fileSize}, #{item.identify}, #{item.status}, #{item.dataId}, #{item.dataName})
        </foreach>
    </insert>

    <update id="updateList">
        <foreach collection="updateReportList" item="item" index="index" separator=";">
            UPDATE htht_cluster_schedule_data_report AS r
            SET r.update_time = now(), r.file_num = #{item.fileNum}, r.sum_num = #{item.sumNum}, r.file_size = #{item.fileSize}, r.status =
            #{item.status}, r.version = r.version + 1
            WHERE r.issue = #{item.issue} AND r.data_id = #{item.dataId}
        </foreach>
    </update>

</mapper>