<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN" "http://mybatis.org/dtd/mybatis-3-mapper.dtd">

<mapper namespace="com.htht.executor.product.dao.ProductDao">

	<!-- 可根据自己的需求，是否要使用 -->
    <resultMap type="com.htht.executor.product.entity.ProductEntity" id="productMap">
        <result property="id" column="id"/>
        <result property="createTime" column="create_time"/>
        <result property="updateTime" column="update_time"/>
        <result property="version" column="version"/>
        <result property="bz" column="bz"/>
        <result property="cycle" column="cycle"/>
        <result property="featureName" column="feature_name"/>
        <result property="gdbPath" column="gdb_path"/>
        <result property="iconPath" column="icon_path"/>
        <result property="isRelease" column="is_release"/>
        <result property="mapUrl" column="map_url"/>
        <result property="mark" column="mark"/>
        <result property="name" column="name"/>
        <result property="sortNo" column="sort_no"/>
        <result property="productPath" column="product_path"/>
        <result property="treeId" column="tree_id"/>
        <result property="issue" column="issue"/>
        <result property="featurename" column="featurename"/>
        <result property="gdbpath" column="gdbpath"/>
        <result property="mapurl" column="mapurl"/>
        <result property="menu" column="menu"/>
        <result property="menuId" column="menu_id"/>
        <result property="storagepath" column="storagepath"/>
        <result property="userid" column="userid"/>
        <result property="triggerParam" column="trigger_param"/>
    </resultMap>
    <select id="selectProductBaseCfgInfo" resultType="com.htht.executor.statistics.entity.CategoryProductDto">
    SELECT
	    p.id AS product_id,
	    CONCAT(d.text,"_",p.NAME) AS NAME,
	    p.cycle AS cycle,
	    c.id AS category_id,
	    c.parent_id AS parent_id
    FROM
	    `htht_cluster_schedule_data_category` AS c
	    LEFT JOIN `htht_cluster_schedule_data_category` AS d ON d.id = c.parent_id
	    LEFT JOIN `htht_cluster_schedule_product` AS p ON c.id = p.tree_id
    WHERE
	    c.tree_key = #{treeKey}
    </select>

    <select id="selectCimisInfoFromTable" resultType="java.util.Map">
        SELECT
            ${txtCols}
        FROM
            ${tableName}
        WHERE `Year` = #{year} and Mon = #{mon} and `Day` = #{day}
        ORDER BY YEAR,Mon,Day desc
    </select>
    <select id="selectCimisInfoFromTableMon" resultType="java.util.Map">
        SELECT
            ${txtCols}
        FROM
            ${tableName}
        WHERE `Year` = #{year} and Mon = #{mon}
        ORDER BY YEAR,Mon desc
    </select>


</mapper>