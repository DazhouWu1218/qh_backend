<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN" "http://mybatis.org/dtd/mybatis-3-mapper.dtd">

<mapper namespace="com.htht.job.admin.template.dao.TemplateParametersDao">

	<!-- 可根据自己的需求，是否要使用 -->
    <resultMap type="com.htht.job.admin.template.entity.TemplateParametersEntity" id="templateParametersMap">
        <result property="id" column="id"/>
        <result property="createTime" column="create_time"/>
        <result property="updateTime" column="update_time"/>
        <result property="version" column="version"/>
        <result property="templateId" column="template_id"/>
        <result property="identify" column="identify"/>
        <result property="des" column="des"/>
        <result property="type" column="type"/>
        <result property="control" column="control"/>
        <result property="currentValue" column="current_value"/>
        <result property="controlJson" column="control_json"/>
    </resultMap>
    <select id="selectTemplateParamListByAlgorithmId"
            resultType="com.htht.job.admin.template.entity.TemplateParametersEntity">
        SELECT a.* FROM `htht_cluster_schedule_template_parameters` a
        LEFT JOIN htht_cluster_schedule_algorithm b
        ON a.template_id = b.template_id
        WHERE b.id = #{id}
        ORDER BY sort_key asc
    </select>
    <select id="selectTemplateParamListByPluginId"
            resultType="com.htht.job.admin.template.entity.TemplateParametersEntity">
        SELECT a.* FROM `htht_cluster_schedule_template_parameters` a
        LEFT JOIN htht_cluster_schedule_handler b
        ON a.template_id = b.template_id
        WHERE b.id = #{id}
        ORDER BY sort_key asc
    </select>


</mapper>